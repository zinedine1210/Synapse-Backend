// Synapse Backend – Prisma Schema
// PostgreSQL via Supabase

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// ==============================
// Enums
// ==============================

enum Role {
  USER
  SUPERADMIN
}

enum ForumCategory {
  DISCUSSION
  QUESTION
  ANNOUNCEMENT
  POLL
  REMINDER
}

enum TaskType {
  ESSAY
  MULTIPLE_CHOICE
  MIXED
}

enum Visibility {
  SHARED
  PRIVATE
}

// ==============================
// Models
// ==============================

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  fullName               String
  avatarUrl              String?
  role                   Role                        @default(USER)
  plan                   String                      @default("FREE")
  planExpiresAt          DateTime?
  dataRetentionDeadline  DateTime?
  uploadCount            Int                         @default(0)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  classes                ClassMember[]
  payments               Payment[]
  attempts               QuizAttempt[]
  notifications          Notification[]
  pricingPlan            PricingPlan                 @relation(fields: [plan], references: [name])
  forumPosts             ForumPost[]
  forumReplies           ForumReply[]
  forumVotes             ForumVote[]
  forumDiscussions       ForumDiscussion[]
  pollVotes              ForumPollVote[]
  kolektifTx             KolektifTransaction[]
  taskSubmissions        TaskSubmission[]
  taskGroupMembers       TaskGroupMember[]
  forumReadStatuses      ForumReadStatus[]
  transactions           Transaction[]
  categoryBudgets        CategoryBudget[]
  savingTrees            SavingTree[]
  bawelSetting           BawelSetting?
  personalTodos          PersonalTodo[]
  sharedTodosReceived    SharedTodo[]            @relation("sharedTodoRecipient")
  sharedTodosSent        SharedTodo[]            @relation("sharedTodoSender")
  qnaQuestions           QnaQuestion[]
  qnaAnswers             QnaAnswer[]
  reputation             UserReputation?
  dailyBriefings         DailyBriefing[]
  gamification           UserGamification?
  xpTransactions         XpTransaction[]
  foodPreference         FoodPreference?
  splitBills             SplitBill[]
  notificationPref       NotificationPreference?
  pushSubscriptions      PushSubscription[]
  todoCategories         TodoCategory[]
  receiptScans           ReceiptScan[]
  onboardingCompleted    Boolean                     @default(false)
  settings               UserSettings?
  qnaVotes               QnaVote[]
  qnaReports             QnaReport[]
  qnaBookmarks           QnaBookmark[]
  qnaQuestionVotes       QnaQuestionVote[]
  subscriptionDismissals SubscriptionDismissal[]
  weeklyProgress         WeeklyChallengeProgress[]
  foodFavorites          FoodFavorite[]
  foodHistory            FoodRecommendationHistory[]
  foodRatings            FoodRating[]
  mealPlans              MealPlan[]
  mealCatalog            UserMealCatalog[]
  profile                UserProfile?
  recurringBills         RecurringBill[]
  thesisProjects         ThesisProject[]
  thesisLikes            ThesisLike[]
  thesisBookmarks        ThesisBookmark[]
  thesisComments         ThesisComment[]
  debts                  Debt[]
  wishlistItems          WishlistItem[]
  budgetChallenges       BudgetChallenge[]
  customCategories       CustomCategory[]
  aiJobs                 AiJob[]
  aiUsageLogs            AiUsageLog[]
}

model Class {
  id                String            @id @default(uuid())
  name              String
  description       String?
  ownerId           String
  lecturer          String?
  day               String?
  time              String?
  room              String?
  password          String?
  forumReadStatuses ForumReadStatus[]
  code              String?           @unique
  joinMode          String            @default("PUBLIC") // "PUBLIC" | "APPROVAL"
  autoRoleAssign    Boolean           @default(false) // auto-assign Admin role to new members
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          Session[]
  members           ClassMember[]
  roles             ClassRole[]
  forumPosts        ForumPost[]
  forumDiscussions  ForumDiscussion[]
  kolektif          Kolektif[]
  tasks             Task[]
  taskGroups        TaskGroup[]
  examPredictions   ExamPrediction[]
  customTabs        ClassCustomTab[]
}

model ClassMember {
  id          String  @id @default(uuid())
  classId     String
  userId      String
  role        String // "OWNER" | "MEMBER"
  status      String  @default("ACTIVE") // "ACTIVE" | "PENDING"
  classRoleId String?

  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classRole ClassRole? @relation(fields: [classRoleId], references: [id], onDelete: SetNull)

  @@unique([classId, userId])
}

model ClassRole {
  id          String   @id @default(uuid())
  classId     String
  name        String // e.g. "Bendahara", "Sekretaris", "Koordinator"
  permissions String[] // e.g. ["MANAGE_KAS", "EDIT_CLASS", "MANAGE_MEMBERS", ...]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  class   Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  members ClassMember[]

  @@unique([classId, name])
}

model Session {
  id        String   @id @default(uuid())
  classId   String
  title     String
  sequence  Int // 1-16
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class       Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  materials   Material[]
  quizzes     Quiz[]
  tasks       Task[]
  discussions ForumDiscussion[]

  @@index([classId])
}

model Material {
  id            String     @id @default(uuid())
  sessionId     String
  uploaderId    String?
  fileName      String
  fileUrl       String
  fileType      String // "PDF" | "AUDIO" | "IMAGE"
  fileSizeBytes Int?
  aiSummary     String?    @db.Text
  status        String     @default("PENDING")
  errorMsg      String?
  visibility    Visibility @default(SHARED)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
}

model Quiz {
  id          String   @id @default(uuid())
  sessionId   String
  question    String   @db.Text // Soal AI (JSON format untuk pilihan ganda)
  answerKey   String
  explanation String?  @db.Text
  createdAt   DateTime @default(now())

  session  Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  score     Int
  passed    Boolean
  answers   String?  @db.Text // JSON snapshot jawaban user
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  orderId           String   @unique // ID Transaksi Midtrans
  snapToken         String?
  grossAmount       Float
  transactionStatus String // "pending" | "settlement" | "expire" | "cancel"
  plan              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  category  String? // "kelas" | "keuangan" | "todo" | "achievement" | "qna"
  actionUrl String? // deep link URL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// Config kuota & akses fitur per plan (dikontrol dari Superadmin)
model PricingPlan {
  id                    String   @id @default(uuid())
  name                  String   @unique // e.g. "FREE", "PRO"
  description           String?
  maxUploadPerMonth     Int      @default(5)
  maxFileSizeMb         Int      @default(10)
  aiRequestLimit        Int      @default(10)
  aiBriefingLimit       Int      @default(1)   // per day
  aiWeeklyRoastLimit    Int      @default(1)   // per week
  aiFoodLimit           Int      @default(5)   // per day
  aiDigitalizationLimit Int      @default(5)   // per day
  aiInsightLimit        Int      @default(3)   // per day
  aiExamPredictionLimit Int      @default(3)   // per day
  aiQuizGenLimit        Int      @default(5)   // per day
  aiReceiptScanLimit    Int      @default(5)   // per day
  aiSkripsweetLimit     Int      @default(10)  // per day
  aiTodoParseLimit      Int      @default(10)  // per day
  features              String[] // e.g. ["class", "quiz", "schedule_parser", "pdf_export"]
  price                 Float    @default(0)
  durationDays          Int      @default(0) // 0 = unlimited, 30 = 1 month, 365 = 1 year
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  users                 User[]
}

model PromoDiscount {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?
  discountType    String   @default("percent") // "percent" or "fixed"
  discountPercent Int      @default(0) // 1-100 (used when discountType = "percent")
  discountAmount  Float    @default(0) // fixed Rp amount (used when discountType = "fixed")
  maxUses         Int      @default(0) // 0 = unlimited
  usedCount       Int      @default(0)
  applicablePlans String[] // e.g. ["PRO", "PRO_YEARLY"]
  autoApply       Boolean  @default(false) // true = automatically applied without code
  validFrom       DateTime @default(now())
  validUntil      DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==============================
// Forum, Polls, Attachments & Reminders
// ==============================

model ForumDiscussion {
  id              String   @id @default(uuid())
  classId         String
  authorId        String
  title           String
  description     String?  @db.Text
  taskId          String? // optional: linked task for context
  sessionId       String? // optional: linked session/pertemuan for context
  assignType      String   @default("ALL") // ALL, INDIVIDUAL, GROUP
  assignedUserIds String[] // userId array when assignType = INDIVIDUAL
  assignedGroupId String? // TaskGroup ID when assignType = GROUP
  isDefault       Boolean  @default(false) // true for "Umum" discussion
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class   Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  author  User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task    Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  session Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  posts   ForumPost[]

  @@index([classId])
}

model ForumPost {
  id           String        @id @default(uuid())
  classId      String
  authorId     String
  discussionId String?
  title        String
  content      String        @db.Text
  category     ForumCategory @default(DISCUSSION)
  isPinned     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  class       Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  discussion  ForumDiscussion?  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  replies     ForumReply[]
  votes       ForumVote[]
  poll        ForumPoll?
  attachments ForumAttachment[]
  reminder    ForumReminder?

  @@index([classId])
  @@index([discussionId])
}

model ForumReply {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post        ForumPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes       ForumVote[]
  attachments ForumAttachment[]

  @@index([postId])
}

model ForumVote {
  id      String  @id @default(uuid())
  userId  String
  postId  String?
  replyId String?
  value   Int // +1 or -1

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply ForumReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
}

model ForumPoll {
  id        String   @id @default(uuid())
  postId    String   @unique
  question  String
  multiple  Boolean  @default(false) // allow multi-select
  createdAt DateTime @default(now())

  post    ForumPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options ForumPollOption[]
}

model ForumPollOption {
  id     String @id @default(uuid())
  pollId String
  label  String
  order  Int    @default(0)

  poll  ForumPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes ForumPollVote[]
}

model ForumPollVote {
  id       String @id @default(uuid())
  optionId String
  userId   String

  option ForumPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model ForumAttachment {
  id            String   @id @default(uuid())
  postId        String?
  replyId       String?
  uploaderName  String?
  fileName      String
  fileUrl       String
  fileType      String // "IMAGE" | "DOCUMENT" | "OTHER"
  fileSizeBytes Int?
  createdAt     DateTime @default(now())

  post  ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply ForumReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model ForumReminder {
  id        String   @id @default(uuid())
  postId    String   @unique
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ForumReadStatus {
  id           String   @id @default(uuid())
  userId       String
  classId      String
  discussionId String? // null = "Umum" discussion
  lastReadAt   DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classId, discussionId])
}

// ==============================
// Kolektif (Treasury / Kas Kelas)
// ==============================

model Kolektif {
  id              String   @id @default(uuid())
  classId         String
  name            String // e.g. "Kas Semester 5", "Patungan Modul"
  description     String?
  targetAmount    Float?
  targetPerPerson Float? // Target iuran per anggota
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class        Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  transactions KolektifTransaction[]
}

model KolektifTransaction {
  id          String   @id @default(uuid())
  kolektifId  String
  userId      String
  amount      Float
  type        String // "IN" | "OUT"
  description String?
  createdAt   DateTime @default(now())

  kolektif Kolektif @relation(fields: [kolektifId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// Tugas (Tasks / Assignments)
// ==============================

model Task {
  id                  String     @id @default(uuid())
  classId             String
  sessionId           String? // null = class-wide task
  title               String
  description         String?    @db.Text
  descriptionImageUrl String? // uploaded photo of the task/soal
  taskType            TaskType   @default(MIXED)
  deadline            DateTime?
  visibility          Visibility @default(SHARED)
  assignType          String     @default("ALL") // "ALL" | "INDIVIDUAL" | "GROUP"
  assignedUserIds     String[] // userId array when assignType = INDIVIDUAL
  createdById         String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  class       Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  session     Session?          @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  submissions TaskSubmission[]
  discussions ForumDiscussion[]
  taskGroup   TaskGroup?        @relation(fields: [taskGroupId], references: [id])
  taskGroupId String?

  @@index([classId])
  @@index([sessionId])
  @@index([deadline])
}

model TaskSubmission {
  id         String   @id @default(uuid())
  taskId     String
  userId     String
  content    String?  @db.Text // manual text input
  imageUrl   String? // uploaded image of question
  aiAnswer   String?  @db.Text // AI generated answer
  visibility String   @default("PRIVATE") // PRIVATE | PUBLIC
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model TaskGroup {
  id        String   @id @default(uuid())
  classId   String
  name      String // e.g. "Kelompok 1"
  createdAt DateTime @default(now())

  class   Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  members TaskGroupMember[]
  tasks   Task[]
}

model TaskGroupMember {
  id      String @id @default(uuid())
  groupId String
  userId  String

  group TaskGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ==============================
// Exam Predictions (Prediksi Ujian)
// ==============================

model ExamPrediction {
  id          String   @id @default(uuid())
  classId     String
  title       String // "UTS Genap 2025", "UAS Semester 5"
  description String?  @db.Text
  createdById String
  sessionIds  String[] // Pertemuan mana saja yang masuk ujian
  source      String // "AI_GENERATED" | "UPLOADED" | "KISI_KISI" | "MANUAL"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class     Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions ExamPredictionQuestion[]

  @@index([classId])
}

model ExamPredictionQuestion {
  id           String   @id @default(uuid())
  predictionId String
  type         String // "ESSAY" | "MULTIPLE_CHOICE"
  question     String   @db.Text
  options      String?  @db.Text // JSON array for multiple choice
  answerKey    String?  @db.Text
  explanation  String?  @db.Text
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  prediction ExamPrediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
}

model ClassCustomTab {
  id           String   @id @default(uuid())
  classId      String
  discussionId String? // null = "Umum" discussion
  name         String
  content      String   @default("") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  files ClassCustomTabFile[]
}

model ClassCustomTabFile {
  id            String   @id @default(uuid())
  tabId         String
  fileName      String
  fileUrl       String
  fileType      String // "IMAGE" | "DOCUMENT" | "OTHER"
  fileSizeBytes Int?
  uploadedById  String?
  createdAt     DateTime @default(now())

  tab ClassCustomTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
}

// ==============================
// Phase 1 – Personal Features
// ==============================

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  amount          Float
  type            String // "income" | "expense"
  category        String
  subcategory     String?
  label           String
  note            String?
  inputMethod     String   @default("text")
  receiptImageUrl String?
  bawelComment    String?
  bawelLevel      String   @default("info")
  linkedTreeId    String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, category])
}

model CategoryBudget {
  id        String   @id @default(uuid())
  userId    String
  category  String
  amount    Float
  month     Int
  year      Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
}

model SavingTree {
  id            String    @id @default(uuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  treeType      String    @default("oak")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TreeTransaction[]

  @@index([userId])
}

model TreeTransaction {
  id     String   @id @default(uuid())
  treeId String
  amount Float
  type   String // "deposit" | "withdrawal"
  note   String?
  date   DateTime @default(now())

  tree SavingTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@index([treeId])
}

model BawelSetting {
  userId          String   @id
  level           String   @default("NORMAL")
  isEnabled       Boolean  @default(true)
  // Si Bawel Memory & Evolution
  memory          String?  @db.Text // Compressed personality memory (JSON: key facts about user)
  personalityStage String  @default("NEWBIE") // NEWBIE -> KENAL -> SAHABAT -> BESTIE
  interactionCount Int     @default(0)
  lastInteraction  DateTime?
  financialDna     String?  @db.Text // Compact financial profile summary (updated weekly)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalTodo {
  id              String    @id @default(uuid())
  userId          String
  title           String
  description     String?
  dueDate         DateTime?
  dueTime         String?
  priority        String    @default("medium")
  category        String?
  tags            String[]  @default([])
  status          String    @default("pending")
  completedAt     DateTime?
  sortOrder       Int       @default(0)
  recurrence      String? // "daily" | "weekly" | "monthly"
  parentTodoId    String?
  // Event/Jadwal fields
  type            String    @default("todo") // "todo" | "event"
  startTime       String? // HH:mm for events
  endTime         String? // HH:mm for events
  location        String?
  eventType       String? // "meeting" | "kuliah" | "ujian" | "penting" | "lainnya"
  reminderMinutes Int[]     @default([]) // e.g. [5, 15, 30, 60, 1440]
  sourceType      String? // "manual" | "class-session" | "task-deadline" | "exam"
  sourceId        String? // FK to source entity
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders TodoReminder[]
  subtasks  TodoSubtask[]
  sharedWith SharedTodo[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, type])
}

model SharedTodo {
  id        String   @id @default(uuid())
  todoId    String
  userId    String   // the user this todo is shared with
  sharedBy  String   // who shared it
  role      String   @default("viewer") // "viewer" | "editor"
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  todo PersonalTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user User         @relation("sharedTodoRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sharer User       @relation("sharedTodoSender", fields: [sharedBy], references: [id], onDelete: Cascade)

  @@unique([todoId, userId])
  @@index([userId, accepted])
  @@index([todoId])
}

model TodoReminder {
  id       String   @id @default(uuid())
  todoId   String
  remindAt DateTime
  sent     Boolean  @default(false)

  todo PersonalTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
  @@index([remindAt, sent])
}

model QnaQuestion {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String?
  category  String[]
  tags      String[]
  slug      String   @unique
  status    String   @default("open")
  isPublic  Boolean  @default(true)
  viewCount Int      @default(0)
  upvotes   Int      @default(0)
  aiAnswer  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   QnaAnswer[]
  bookmarks QnaBookmark[]
  qVotes    QnaQuestionVote[]

  @@index([userId])
  @@index([slug])
  @@index([status])
}

model QnaAnswer {
  id                String   @id @default(uuid())
  questionId        String
  userId            String
  body              String
  isApprovedByAsker Boolean  @default(false)
  isAIFiltered      Boolean  @default(false)
  upvotes           Int      @default(0)
  reportCount       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  question QnaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes    QnaVote[]
  reports  QnaReport[]

  @@index([questionId])
  @@index([userId])
}

model UserReputation {
  id              String @id @default(uuid())
  userId          String @unique
  score           Int    @default(0)
  answersApproved Int    @default(0)
  questionsAsked  Int    @default(0)
  reportCount     Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyBriefing {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ==============================
// Gamification
// ==============================

model UserGamification {
  id             String    @id @default(uuid())
  userId         String    @unique
  totalXp        Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?
  achievements   String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  source      String
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ==============================
// Food Recommendation
// ==============================

model FoodPreference {
  userId              String   @id
  dislikedIngredients String[]
  preferredCuisines   String[]
  spicyLevel          Int      @default(1)
  dietType            String   @default("none")
  avgMealBudget       Float?
  calorieLimit        Int?     // Max daily calorie target
  proteinTarget       Int?     // Daily protein target in grams
  healthGoals         String[] // e.g. ["lose_weight", "build_muscle", "eat_healthier"]
  allergies           String[] // e.g. ["kacang", "seafood", "gluten"]
  breakfastHabit      String?  @db.Text // What user usually eats for breakfast
  lunchHabit          String?  @db.Text // What user usually eats for lunch
  dinnerHabit         String?  @db.Text // What user usually eats for dinner
  snackHabit          String?  @db.Text // What user usually snacks on

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// Split Bill
// ==============================

model SplitBill {
  id              String   @id @default(uuid())
  userId          String
  eventName       String?
  totalAmount     Float
  receiptImageUrl String?
  status          String   @default("settling")
  splitMethod     String   @default("item") // "item" | "percentage"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        SplitBillItem[]
  participants SplitParticipant[]

  @@index([userId])
}

model SplitBillItem {
  id         String   @id @default(uuid())
  billId     String
  name       String
  price      Float
  quantity   Int      @default(1)
  assignedTo String[]

  bill SplitBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model SplitParticipant {
  id         String  @id @default(uuid())
  billId     String
  name       String
  totalOwed  Float   @default(0)
  isPaid     Boolean @default(false)
  percentage Float? // used when splitMethod = "percentage"

  bill SplitBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ==============================
// Notification Preferences
// ==============================

model NotificationPreference {
  userId           String  @id
  deadlineReminder Boolean @default(true)
  budgetAlert      Boolean @default(true)
  streakReminder   Boolean @default(true)
  idleReminder     Boolean @default(true)
  weeklyRecap      Boolean @default(true)
  forumReply       Boolean @default(true)
  qnaAnswer        Boolean @default(true)
  achievementAlert Boolean @default(true)
  mealReminder     Boolean @default(true)
  todoReminder     Boolean @default(true)
  debtReminder     Boolean @default(true)
  splitBillReminder Boolean @default(true)
  billReminder     Boolean @default(true)
  scheduleReminder Boolean @default(true)
  materialNotif    Boolean @default(true)
  quietHoursStart  String?
  quietHoursEnd    String?
  pushEnabled      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// Push Subscriptions (Web Push)
// ==============================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

// ==============================
// Todo Categories (Custom)
// ==============================

model TodoCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  emoji     String   @default("📌")
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

// ==============================
// Receipt Scan
// ==============================

model ReceiptScan {
  id          String    @id @default(uuid())
  userId      String
  imageUrl    String
  storeName   String?
  scanDate    DateTime?
  totalAmount Float?
  itemCount   Int       @default(0)
  status      String    @default("processed")
  rawResponse String?   @db.Text
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==============================
// Q&A Upvote Persistence (replaces in-memory Set)
// ==============================

model QnaVote {
  id        String   @id @default(uuid())
  userId    String
  answerId  String
  value     Int      @default(1) // +1 upvote
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer QnaAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
  @@index([answerId])
}

// ==============================
// User Settings / Preferences
// ==============================

model UserSettings {
  userId          String    @id
  theme           String    @default("system") // "light" | "dark" | "system"
  language        String    @default("id") // "id" | "en"
  exportRequested DateTime?
  accountStatus   String    @default("ACTIVE") // "ACTIVE" | "DELETED"
  deletedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// Todo Sub-tasks
// ==============================

model TodoSubtask {
  id        String   @id @default(uuid())
  todoId    String
  title     String
  isDone    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  todo PersonalTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
}

// ==============================
// Subscription Dismissal (for "Bocor Halus")
// ==============================

model SubscriptionDismissal {
  id        String   @id @default(uuid())
  userId    String
  pattern   String // serialized pattern key (e.g., "spotify_monthly")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pattern])
  @@index([userId])
}

// ==============================
// Q&A Answer Reports
// ==============================

model QnaReport {
  id        String   @id @default(uuid())
  userId    String
  answerId  String
  reason    String?
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer QnaAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
}

// ==============================
// Q&A Bookmarks
// ==============================

model QnaBookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QnaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

// ==============================
// Q&A Question Votes
// ==============================

model QnaQuestionVote {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  value      Int      @default(1) // +1 upvote, -1 downvote
  createdAt  DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QnaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

// ==============================
// Weekly Challenge (Gamification)
// ==============================

model WeeklyChallenge {
  id          String   @id @default(uuid())
  title       String
  description String?
  targetType  String // "transactions_count" | "savings_amount" | "todos_done" | "answers_given"
  targetValue Int
  rewardXp    Int
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  progress WeeklyChallengeProgress[]
}

model WeeklyChallengeProgress {
  id          String  @id @default(uuid())
  challengeId String
  userId      String
  current     Int     @default(0)
  completed   Boolean @default(false)

  challenge WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

// ==============================
// Food Favorites
// ==============================

model FoodFavorite {
  id         String   @id @default(uuid())
  userId     String
  recipeName String
  recipeData String   @db.Text // JSON serialized recipe
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==============================
// Food Recommendation History
// ==============================

model FoodRecommendationHistory {
  id         String   @id @default(uuid())
  userId     String
  recipeName String
  recipeData String?
  sourceType String?  // 'fridge', 'menu', 'text', 'meal_plan'
  budget     Float?
  createdAt  DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratings FoodRating[]

  @@index([userId, createdAt])
}

model FoodRating {
  id        String   @id @default(uuid())
  userId    String
  historyId String
  rating    Int      // 1-5
  feedback  String?
  createdAt DateTime @default(now())

  user    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  history FoodRecommendationHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@unique([userId, historyId])
  @@index([userId])
}

// ==============================
// Meal Plan Tracking
// ==============================

model MealPlan {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime // Start of the week (Monday)
  planData    String   @db.Text // JSON: full MealPlanResult
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries MealPlanEntry[]

  @@index([userId, weekStart])
  @@unique([userId, weekStart])
}

model MealPlanEntry {
  id         String    @id @default(uuid())
  planId     String
  day        Int       // 1-7
  mealType   String    // breakfast, lunch, dinner
  completed  Boolean   @default(false)
  completedAt DateTime?
  skipped    Boolean   @default(false)
  actualCost Float?    // Real cost if user provides it

  plan MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@unique([planId, day, mealType])
}

// User's known meals with real pricing
model UserMealCatalog {
  id        String   @id @default(uuid())
  userId    String
  name      String   // "Nasi Padang"
  mealType  String   // breakfast, lunch, dinner, snack
  price     Float    // Real price user pays
  calories  Int?
  protein   Int?
  tags      String[] // ["berat", "enak", "mahal"]
  source    String?  // "kantin kantor", "warteg depan kos"
  frequency Int      @default(1) // How often user eats this per week
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==============================
// AI Job Tracking
// ==============================

model AiJob {
  id          String    @id @default(uuid())
  userId      String
  jobType     String
  status      String    @default("PROCESSING") // PROCESSING, COMPLETED, FAILED, DISMISSED
  result      String?   @db.Text
  error       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, jobType])
  @@index([userId, jobType, status])
}

// ==============================
// AI Usage Log
// ==============================

model AiUsageLog {
  id        String   @id @default(uuid())
  userId    String
  feature   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
}

// ==============================
// User Profile (AI Context & Onboarding Data)
// ==============================

model UserProfile {
  userId        String   @id
  university    String?
  hobbies       String[]
  job           String?
  reason        String?
  avatarUrl     String?
  dailyHabits   String?  @db.VarChar(300)
  lifeGoals     String?  @db.VarChar(300)
  studySchedule String?  @db.VarChar(200)
  personalNotes String?  @db.VarChar(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==============================
// Recurring Bills / Tagihan
// ==============================

model RecurringBill {
  id          String    @id @default(uuid())
  userId      String
  name        String
  amount      Float
  category    String    @default("tagihan")
  dueDay      Int
  isActive    Boolean   @default(true)
  lastPaidAt  DateTime?
  lastPaidFor DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

// ==============================
// Debts / Hutang
// ==============================

model Debt {
  id                  String    @id @default(uuid())
  userId              String
  description         String
  amount              Float
  debtType            String    @default("owed_by_me")
  personName          String
  dueDate             DateTime?
  isPaid              Boolean   @default(false)
  paidAt              DateTime?
  linkedTransactionId String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isPaid])
}

// ==============================
// Wishlist / Rencana Belanja
// ==============================

model WishlistItem {
  id                  String    @id @default(uuid())
  userId              String
  name                String
  estimatedPrice      Float
  priority            String    @default("medium") // high, medium, low
  category            String?
  targetDate          DateTime?
  notes               String?
  url                 String?   // link produk/toko
  isPurchased         Boolean   @default(false)
  purchasedAt         DateTime?
  linkedTransactionId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isPurchased])
}

// ==============================
// Budget Challenge & Streak
// ==============================

model BudgetChallenge {
  id            String    @id @default(uuid())
  userId        String
  title         String
  description   String?
  type          String    @default("daily_limit") // daily_limit, weekly_limit, no_spend_day, category_limit
  targetAmount  Float?    // spending limit amount
  targetDays    Int       @default(7) // challenge duration in days
  category      String?   // optional: category-specific challenge
  startDate     DateTime
  endDate       DateTime
  currentStreak Int       @default(0)
  bestStreak    Int       @default(0)
  isActive      Boolean   @default(true)
  completedDays Int       @default(0)
  failedDays    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

// ==============================
// Custom Categories
// ==============================

model CustomCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  emoji     String   @default("📦")
  type      String   @default("expense") // income | expense
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([userId])
}

// ==============================
// Skripsweet — Thesis Assistant
// ==============================

model ThesisProject {
  id              String   @id @default(uuid())
  userId          String
  title           String
  university      String?
  faculty         String?
  department      String?
  supervisor      String?  // Dosen pembimbing 1
  supervisorTwo   String?  // Dosen pembimbing 2
  status          String   @default("draft") // draft | in_progress | review | revision | completed
  startDate       DateTime?
  targetDate      DateTime?
  abstract        String?  @db.Text
  notes           String?  @db.Text
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  tags            String[] // e.g. ["machine-learning", "nlp", "deep-learning"]
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  formatTemplate  ThesisFormatTemplate?
  chapters        ThesisChapter[]
  chapterRevisions ChapterRevision[]
  journals        ThesisJournal[]
  bimbingans      ThesisBimbingan[]
  chatMessages    ThesisChatMessage[]
  bibliographies  ThesisBibliography[]
  likes           ThesisLike[]
  bookmarks       ThesisBookmark[]
  comments        ThesisComment[]

  @@index([userId])
  @@index([isPublished, updatedAt])
}

model ThesisFormatTemplate {
  id              String   @id @default(uuid())
  thesisId        String   @unique
  universityName  String?  // Nama kampus (jika mau reuse)
  formatRules     String   @db.Text // JSON: detailed format rules (margins, fonts, spacing, chapter structure, etc.)
  chapterTemplate String?  @db.Text // JSON: default chapter structure based on university format
  citationStyle   String   @default("apa7") // apa7 | ieee | chicago | vancouver | custom
  customCitation  String?  @db.Text // Custom citation format rules (if citationStyle == 'custom')
  language        String   @default("id") // id | en
  rawUploadText   String?  @db.Text // Raw text extracted from uploaded format guide
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)
}

model ThesisChapter {
  id              String   @id @default(uuid())
  thesisId        String
  title           String   // e.g., "BAB I - Pendahuluan"
  chapterNum      Int      // 1, 2, 3, ...
  status          String   @default("not_started") // not_started | drafting | reviewing | revision | done
  content         String?  @db.Text // The actual chapter content/draft (HTML from Tiptap)
  wordCount       Int      @default(0)
  targetWords     Int?     // Target word count for this chapter
  targetPages     Int?     // Target page count
  targetParagraphs Int?    // Target paragraph count
  paragraphCount  Int      @default(0) // Actual paragraph count
  pageEstimate    Float    @default(0) // Estimated pages (words/250)
  notes           String?  @db.Text
  aiSuggestion    String?  @db.Text // Last AI feedback/suggestion
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  thesis    ThesisProject    @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  revisions ChapterRevision[]
  versions  ChapterVersion[]

  @@index([thesisId])
  @@unique([thesisId, chapterNum])
}

model ChapterRevision {
  id         String    @id @default(uuid())
  chapterId  String
  thesisId   String
  note       String    @db.Text
  status     String    @default("pending") // pending | resolved
  round      Int       @default(1)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  chapter ThesisChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  thesis  ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([thesisId])
}

model ChapterVersion {
  id        String   @id @default(uuid())
  chapterId String
  content   String   @db.Text
  wordCount Int      @default(0)
  label     String?  // Optional label e.g. "Sebelum revisi dosen"
  createdAt DateTime @default(now())

  chapter ThesisChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model ThesisJournal {
  id            String   @id @default(uuid())
  thesisId      String
  title         String
  authors       String?
  journalName   String?  // Name of journal/conference
  year          Int?
  doi           String?
  url           String?
  abstract      String?  @db.Text
  relevance     String?  @db.Text // Why is this relevant to the thesis
  notes         String?  @db.Text
  isFromSearch  Boolean  @default(false) // Found via Semantic Scholar API
  bibtex        String?  @db.Text
  citationKey   String?  // e.g., "Smith2024" for in-text citation
  addedAt       DateTime @default(now())

  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
}

model ThesisBimbingan {
  id          String   @id @default(uuid())
  thesisId    String
  date        DateTime
  supervisor  String?  // Which supervisor (1 or 2)
  topic       String   // What was discussed
  feedback    String?  @db.Text // Feedback from supervisor
  actionItems String?  @db.Text // JSON array of action items
  status      String   @default("pending") // pending | done
  attachment  String?  // URL to uploaded file
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
}

model ThesisChatMessage {
  id        String   @id @default(uuid())
  thesisId  String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  context   String?  // Which chapter/section the question is about
  createdAt DateTime @default(now())

  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
}

model ThesisBibliography {
  id            String   @id @default(uuid())
  thesisId      String
  journalId     String?  // Link to ThesisJournal if applicable
  rawEntry      String   @db.Text // The formatted bibliography entry
  citationKey   String   // e.g., "Smith2024"
  entryType     String   @default("article") // article | book | inproceedings | thesis | website | other
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
}

// ==============================
// Skripsweet — Social Features
// ==============================

model ThesisLike {
  id        String   @id @default(uuid())
  userId    String
  thesisId  String
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@unique([userId, thesisId])
  @@index([thesisId])
}

model ThesisBookmark {
  id        String   @id @default(uuid())
  userId    String
  thesisId  String
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@unique([userId, thesisId])
  @@index([userId])
}

model ThesisComment {
  id        String   @id @default(uuid())
  userId    String
  thesisId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  thesis ThesisProject @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
}
