# =====================================================
# Synapse Backend – Environment Variables Template
# =====================================================
# Salin file ini menjadi .env dan isi setiap nilai.
# Server TIDAK AKAN MENYALA jika ada nilai yang kosong.
# Lihat DEVELOPER_SETUP.md untuk panduan lengkap.
# =====================================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# --- Supabase Auth ---
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# --- Google Gemini AI ---
GEMINI_API_KEY="your-google-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"

# --- Midtrans Payment Gateway (Sandbox) ---
MIDTRANS_SERVER_KEY="SB-Mid-server-your-server-key"
MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"
MIDTRANS_IS_PRODUCTION="false"

# --- App Config ---
APP_PORT="3001"
APP_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# --- Rate Limiting ---
THROTTLE_TTL="60"
THROTTLE_LIMIT="30"
